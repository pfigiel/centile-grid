{
  "name": "@centile-grid/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp -r src/data dist/src/data",
    "start": "node dist/main.js",
    "start:dev": "ts-node main.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@centile-grid/contract": "workspace:*",
    "@codegenie/serverless-express": "5.0.0",
    "@nestjs/common": "11.0.0",
    "@nestjs/core": "11.0.0",
    "@nestjs/platform-express": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.0"
  },
  "devDependencies": {
    "@nestjs/testing": "11.0.0",
    "@types/aws-lambda": "8.10.0",
    "@types/jest": "catalog:test",
    "@types/node": "22.0.0",
    "eslint": "catalog:lint",
    "eslint-config-prettier": "catalog:lint",
    "jest": "catalog:test",
    "ts-jest": "catalog:test",
    "ts-node": "10.9.2",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:lint"
  }
}
