{
  "name": "@centile-grid/mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf .expo dist",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:android": "expo prebuild --platform android",
    "build:local:ios": "eas build --local --profile development --platform ios",
    "build:local:android": "eas build --local --profile development --platform android"
  },
  "dependencies": {
    "@centile-grid/contract": "workspace:*",
    "@centile-grid/ui-kit-mobile": "workspace:*",
    "@tanstack/react-query": "5.79.0",
    "@expo/vector-icons": "15.0.3",
    "@react-navigation/bottom-tabs": "7.4.0",
    "@react-navigation/elements": "2.6.3",
    "@react-navigation/native": "7.2.2",
    "expo": "54.0.34",
    "expo-constants": "18.0.13",
    "expo-dev-client": "6.0.21",
    "expo-font": "14.0.11",
    "expo-haptics": "15.0.8",
    "expo-image": "3.0.11",
    "expo-linking": "8.0.12",
    "expo-router": "6.0.23",
    "expo-splash-screen": "31.0.13",
    "expo-status-bar": "3.0.9",
    "expo-symbols": "1.0.8",
    "expo-system-ui": "6.0.9",
    "expo-web-browser": "15.0.11",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-hook-form": "7.75.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-screens": "4.16.0",
    "react-native-web": "0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@centile-grid/eslint-plugin": "workspace:*",
    "@testing-library/react-native": "catalog:test",
    "@types/jest": "catalog:test",
    "@types/react": "catalog:react",
    "eslint": "catalog:lint",
    "eslint-config-expo": "10.0.0",
    "eslint-config-prettier": "catalog:lint",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-prefer-arrow": "catalog:lint",
    "jest": "catalog:test",
    "jest-expo": "catalog:test",
    "react-test-renderer": "catalog:react",
    "typescript": "catalog:"
  },
  "private": true
}
